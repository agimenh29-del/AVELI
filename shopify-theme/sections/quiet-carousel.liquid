<div class="ql-carousel-shell">
  <div class="ql-carousel" data-ql-carousel>
    <div class="ql-carousel-track">
      {% for block in section.blocks %}
        <div class="ql-carousel-item" {{ block.shopify_attributes }}>
          {% if block.settings.video != blank %}
            {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
          {% elsif block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 2200 | image_tag: loading: 'lazy', alt: block.settings.alt }}
          {% endif %}
        </div>
      {% endfor %}

      {% for block in section.blocks %}
        <div class="ql-carousel-item" aria-hidden="true">
          {% if block.settings.video != blank %}
            {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
          {% elsif block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 2200 | image_tag: loading: 'lazy', alt: block.settings.alt }}
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Quiet Carousel",
  "max_blocks": 30,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "video", "id": "video", "label": "Video" },
        { "type": "text", "id": "alt", "label": "Image alt text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quiet Carousel",
      "blocks": [{ "type": "slide" }, { "type": "slide" }, { "type": "slide" }]
    }
  ]
}
{% endschema %}
